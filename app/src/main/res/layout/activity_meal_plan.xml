<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Monday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerMonday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Tuesday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tuesday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerTuesday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Wednesday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wednesday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerWednesday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Thursday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thursday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerThursday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Friday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Friday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerFriday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Saturday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Saturday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerSaturday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Sunday -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sunday"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerSunday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Bucket -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bucket (Unscheduled)"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />
            <LinearLayout
                android:id="@+id/containerBucket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Build Grocery List button -->
            <Button
                android:id="@+id/buildGroceryListButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Build Grocery List"
                android:layout_marginTop="16dp" />

            <!-- Grocery list output -->
            <LinearLayout
                android:id="@+id/groceryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grocery List"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:id="@+id/groceryItemsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
